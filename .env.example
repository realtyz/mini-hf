TZ=Asia/Shanghai

# HF Server 对外访问地址
# 该地址必须配置为终端用户实际能够访问到的 HF API 服务地址：
# - 本地测试/直接暴露端口部署：保持默认值 http://localhost:9801 即可
# - 反向代理/Nginx 部署：需要配置为对外域名（如 https://hf.yourdomain.com）
# - 局域网部署：配置为服务器的局域网 IP + 端口（如 http://192.168.1.100:9801）
# 主要用途：
# 1. 生成分页 API 返回的 Link 头中的 next_url 地址
# 2. 在前端文档中作为推荐的 HF_ENDPOINT 配置值展示给用户
# 3. 生成下载跳转链接时使用（当不直接通过 S3 预签名 URL 下载时）
# 注意：如果配置错误会导致分页跳转失败、模型下载链接无法访问等问题
APP_HF_SERVER_URL='http://localhost:9801'

# Admin User Settings (auto-created on first startup)
# Default: admin@example.com / changeme
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=changeme

# JWT Settings
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Settings
PG_USERNAME=postgres
PG_PASSWORD=123456
PG_DATABASE=mini_hf

# Application Settings
APP_NAME=Mini-HF

# Storage Settings
INCOMPLETE_FILE_PATH=/tmp/mini-hf

# S3 Settings
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_BUCKET_NAME=mini-hf-bucket
S3_REGION=us-east-1
S3_USE_SSL=false
S3_VERIFY_SSL=false
