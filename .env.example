# Admin User Settings (auto-created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin
ADMIN_NAME=Admin

# JWT Settings
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Settings
PG_PASSWORD=123456
PG_DATABASE=mini_hf

# Application Settings
APP_NAME=Mini-HF

# Storage Settings
INCOMPLETE_FILE_PATH=./data/incomplete

# S3 Settings
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_BUCKET_NAME=mini-hf-bucket
S3_REGION=us-east-1
S3_USE_SSL=false
S3_VERIFY_SSL=false